# ===== Server Configuration =====
PORT=5000
NODE_ENV=production

# ===== Database Configuration =====
# Use MongoDB Atlas for cloud database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nayepankh-vms

# ===== JWT Configuration =====
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_secret_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# ===== Frontend URL (CORS) =====
# Allow requests only from your frontend domain
CLIENT_URL=https://your-frontend-domain.com

# ===== Cloudinary Configuration (Image Storage) =====
# Sign up at https://cloudinary.com for free account
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== Email Configuration (Nodemailer) =====
# For Gmail: Enable "App Passwords" in Google Account settings
# For other providers: Check Nodemailer documentation
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=NayePankh Foundation <your_email@gmail.com>

# ===== Admin Credentials (Initial Setup) =====
# Change these to secure values and rotate after setup
# Generated admin will use these credentials
ADMIN_EMAIL=admin@nayepankh.org
ADMIN_PASSWORD=admin12345






